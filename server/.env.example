# Gemini API key (set in Railway, never commit the real one)
GEMINI_KEY=
# Optional: override the Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash
# Comma-separated allowed frontend origins for CORS (localhost is always allowed)
ALLOWED_ORIGIN=https://uber-wrapped.up.railway.app
PORT=8080
